generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(cuid())
  name            String?
  email           String?    @unique
  password        String
  role            Role       @default(STUDENT)
  karma           Int        @default(0)
  createdAt       DateTime   @default(now())
  currentElective String?
  currentSemester Int?
  username        String?    @unique
  accounts        Account[]
  comments        Comment[]
  posts           Post[]
  resources       Resource[]
  sessions        Session[]
  votes           Vote[]
  bookmarks       Bookmark[]
}

model Semester {
  id       Int       @id @default(autoincrement())
  number   Int       @unique
  title    String
  subjects Subject[]
}

model Subject {
  id         String     @id @default(cuid())
  name       String
  code       String
  semesterId Int
  posts      Post[]
  resources  Resource[]
  semester   Semester   @relation(fields: [semesterId], references: [id], onDelete: Cascade)
}

model Resource {
  id           String       @id @default(cuid())
  title        String
  type         ResourceType
  fileName     String
  filePath     String
  year         Int?
  uploadedById String
  subjectId    String
  downloads    Int          @default(0)
  createdAt    DateTime     @default(now())
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
}

model Post {
  id        String    @id @default(cuid())
  title     String
  content   String
  authorId  String
  subjectId String
  isLocked  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  subject   Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  votes     Vote[]
  bookmarks Bookmark[]
}

model Comment {
  id         String    @id @default(cuid())
  content    String
  authorId   String
  postId     String
  parentId   String?
  isAccepted Boolean   @default(false)
  createdAt  DateTime  @default(now())
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")
  post       Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Vote {
  id     String @id @default(cuid())
  value  Int
  userId String
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  MODERATOR
  ADMIN
}

enum ResourceType {
  PAST_PAPER
  NOTES
  MODEL_QUESTION
  SOLUTION
}


model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}
